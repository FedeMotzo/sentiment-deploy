{
  "title": "Sentiment Analysis API",
  "uid": "sentiment-api-v3",
  "timezone": "browser",
  "refresh": "15s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Predizioni totali per sentiment",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
          "expr": "rate(sentiment_predictions_total{sentiment=\"positive\"}[1m])",
          "legendFormat": "positive",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
          "expr": "rate(sentiment_predictions_total{sentiment=\"negative\"}[1m])",
          "legendFormat": "negative",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
          "expr": "rate(sentiment_predictions_total{sentiment=\"neutral\"}[1m])",
          "legendFormat": "neutral",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Latenza richieste (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
          "expr": "histogram_quantile(0.50, rate(sentiment_prediction_latency_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
          "expr": "histogram_quantile(0.95, rate(sentiment_prediction_latency_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
          "expr": "histogram_quantile(0.99, rate(sentiment_prediction_latency_seconds_bucket[1m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "Errori di predizione",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
          "expr": "rate(sentiment_prediction_errors_total[1m])",
          "legendFormat": "errori/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "Utilizzo CPU %",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "sentiment-prometheus" },
          "expr": "sentiment_cpu_usage_percent",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    }
  ]
}